---
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource/inter/variable.css";
import "lenis/dist/lenis.css";

import "assets/styles/base.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.png",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Hadouin"
  : "Hadouin - Web Developper";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#333333" />
    <meta name="msapplication-TileColor" content="#ffc40d" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <ClientRouter />
    <SEO
      title={makeTitle}
      description="I'm a computer science student in Paris. I like to code."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Hadouin - Web developper`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Hadouin HomePage screenshot",
        },
      }}
    />
  </head>
  <body>
    <Navbar />
    <div
      class="hidden xl:flex fixed bottom-0 w-10 items-center justify-center flex-col right-10 left-auto after:h-20 after:w-px after:bg-slate-500">
      <div class="email-sidelink my-5">
        <a
          class="relative no-underline tracking-widest"
          href="mailto:contact@hadouin.com"
          >contact@hadouin.com
        </a>
      </div>
    </div>
    <div
      class="hidden xl:flex fixed bottom-0 w-10 items-center justify-center flex-col left-10 right-auto after:h-20 after:w-px after:bg-slate-500">
      <ul
        class="socials-side flex flex-col justify-center items-center list-none text-slate-700">
        <li class="mb-3">
          <a
            class="flex p-2 transition"
            href="https://github.com/hadouin"
            target="_blank"
            rel="noopener noreferrer">
            <svg class="feather">
              <use href="/feather-sprite.svg#github"></use>
            </svg>
          </a>
        </li>
        <li class="mb-3">
          <a
            class="flex p-2 transition"
            href="https://www.linkedin.com/in/hadouin"
            target="_blank"
            rel="noopener noreferrer">
            <svg class="feather">
              <use href="/feather-sprite.svg#linkedin"></use>
            </svg>
          </a>
        </li>
      </ul>
    </div>
    <div class="pt-[70px]">
      <slot />
    </div>
    <Footer />
    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({
        autoRaf: true,
        anchors: true,
      });

      let parallaxIO: IntersectionObserver | null = null;
      let scrollHandler: (() => void) | null = null;

      const scrambleLetters =
        "abcdefgHijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ?@:/}{()*+-#$&";
      const randomScrambleChar = () =>
        scrambleLetters[Math.floor(Math.random() * scrambleLetters.length)];

      function bindPage() {
        document.querySelectorAll<HTMLElement>(".watermark-hover").forEach((el) => {
          if ((el as any).__watermarkBound) return;
          (el as any).__watermarkBound = true;
          el.addEventListener("mouseenter", () => {
            el.classList.remove("is-scan-out");
            el.classList.add("is-scan-in");
          });
          el.addEventListener("mouseleave", () => {
            el.classList.remove("is-scan-in");
            el.classList.add("is-scan-out");
          });
        });

        document
          .querySelectorAll<HTMLElement>(".scramble-hover")
          .forEach((el) => {
            if ((el as any).__scrambleBound) return;
            (el as any).__scrambleBound = true;
            const target = (el.dataset.scrambleText ?? el.textContent ?? "").trim();
            if (!target) return;
            el.dataset.scrambleText = target;
            let interval: ReturnType<typeof setInterval> | undefined;

            el.addEventListener("mouseenter", () => {
              if (interval) clearInterval(interval);
              let iteration = 0;
              const tickMs = 30;
              const durationMs = 300;
              const step = target.length / (durationMs / tickMs);

              interval = setInterval(() => {
                el.textContent = target
                  .split("")
                  .map((ch, index) => {
                    if (ch === " ") return " ";
                    if (index < iteration) return target[index];
                    return randomScrambleChar();
                  })
                  .join("");

                if (iteration >= target.length) {
                  if (interval) clearInterval(interval);
                  el.textContent = target;
                }
                iteration += step;
              }, tickMs);
            });
          });

        if (parallaxIO) parallaxIO.disconnect();
        if (scrollHandler) lenis.off("scroll", scrollHandler);

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (reduceMotion || isMobile) return;

        const parallaxEls = Array.from(
          document.querySelectorAll<HTMLElement>("[data-parallax]")
        );
        const visible = new Set<HTMLElement>();
        parallaxIO = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              const t = e.target as HTMLElement;
              if (e.isIntersecting) visible.add(t);
              else {
                visible.delete(t);
                t.style.transform = "";
              }
            }
          },
          { rootMargin: "20% 0px 20% 0px" }
        );
        parallaxEls.forEach((el) => {
          el.style.willChange = "transform";
          // Seed with the scroll-accurate transform so the element does not
          // flash at baseline between bindPage() and the first IO callback.
          {
            const vh = window.innerHeight;
            const speed = parseFloat(el.dataset.parallax || "0.05");
            const scale = parseFloat(el.dataset.parallaxScale || "1.08");
            const rect = el.getBoundingClientRect();
            const ec = rect.top + rect.height / 2;
            const offset = (vh / 2 - ec) * speed;
            el.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0) scale(${scale})`;
          }
          parallaxIO!.observe(el);
        });

        const update = () => {
          const vh = window.innerHeight;
          const vc = vh / 2;
          visible.forEach((el) => {
            const speed = parseFloat(el.dataset.parallax || "0.05");
            const scale = parseFloat(el.dataset.parallaxScale || "1.08");
            const rect = el.getBoundingClientRect();
            const ec = rect.top + rect.height / 2;
            const offset = (vc - ec) * speed;
            el.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0) scale(${scale})`;
          });
        };
        scrollHandler = update;
        lenis.on("scroll", update);
        // IO populates `visible` async; flush on the next frame so the first
        // update() sees the real set instead of running empty.
        requestAnimationFrame(() => {
          update();
          requestAnimationFrame(update);
        });
      }

      // Force lenis' animated scroll + internal state to match a target Y
      // instantly. scrollTo({immediate,force}) already does this, but calling
      // resize()+emit nudges its scroll listeners so downstream effects
      // (parallax update) see the new position on the next tick.
      function syncScroll(y: number) {
        lenis.scrollTo(y, { immediate: true, force: true });
        window.scrollTo(0, y);
        lenis.resize();
      }

      // Paint the *real* parallax transform (matching the scroll-driven
      // update loop) so that the view-transition snapshot matches the state
      // the element will settle into after VT ends — no post-morph snap.
      function paintParallax() {
        if (window.matchMedia("(max-width: 767px)").matches) return;
        const vh = window.innerHeight;
        const vc = vh / 2;
        document.querySelectorAll<HTMLElement>("[data-parallax]").forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || "0.05");
          const scale = parseFloat(el.dataset.parallaxScale || "1.08");
          const rect = el.getBoundingClientRect();
          const ec = rect.top + rect.height / 2;
          const offset = (vc - ec) * speed;
          el.style.willChange = "transform";
          el.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0) scale(${scale})`;
        });
      }

      const SCROLL_KEY_PREFIX = "hadouin:scroll:";

      // Persist scroll position before leaving so the destination page can
      // snap back to the matching section during the morph.
      document.addEventListener("astro:before-preparation", () => {
        sessionStorage.setItem(
          SCROLL_KEY_PREFIX + location.pathname,
          String(window.scrollY)
        );
        // Leaving a project detail page: scroll the outgoing doc to top so
        // the hero sits at its natural position in the old snapshot, then
        // recompute parallax so the old snapshot reflects scroll=0 state.
        if (location.pathname.startsWith("/projects/")) {
          syncScroll(0);
          paintParallax();
        }
      });

      // Set the incoming document's scroll and parallax transforms
      // synchronously (before the new snapshot paints) so both the morph
      // target rect and the post-VT real DOM match frame-for-frame.
      document.addEventListener("astro:after-swap", () => {
        if (location.pathname.startsWith("/projects/")) {
          // Forward nav into detail: hero always at top.
          syncScroll(0);
        } else {
          // Priority: URL hash (explicit "back to this project") > saved
          // scroll (user landed here before) > top.
          let y = 0;
          if (location.hash) {
            try {
              const target = document.querySelector(location.hash) as HTMLElement | null;
              if (target) {
                const rect = target.getBoundingClientRect();
                const navOffset = 90;
                y = Math.max(0, Math.round(window.scrollY + rect.top - navOffset));
              }
            } catch {
              /* malformed hash — ignore */
            }
          }
          if (!y) {
            const saved = sessionStorage.getItem(SCROLL_KEY_PREFIX + location.pathname);
            y = saved ? parseInt(saved, 10) : 0;
          }
          syncScroll(y);
        }
        paintParallax();
      });

      function bindContinueReading() {
        const btn = document.getElementById("continue-reading");
        if (!btn) return;
        if (!location.pathname.startsWith("/projects/")) return;
        const key = SCROLL_KEY_PREFIX + location.pathname;
        const saved = sessionStorage.getItem(key);
        const y = saved ? parseInt(saved, 10) : 0;
        if (y <= 120) return;

        // Reveal button after the morph finishes so it does not compete
        // visually with the hero animation.
        setTimeout(() => btn.classList.add("is-visible"), 720);

        const hide = () => btn.classList.remove("is-visible");
        btn.addEventListener("click", () => {
          hide();
          lenis.scrollTo(y, { duration: 1.0 });
          sessionStorage.removeItem(key);
        }, { once: true });

        // Dismiss if the user scrolls themselves.
        const onScroll = () => {
          if (Math.abs(window.scrollY) > 40) {
            hide();
            window.removeEventListener("scroll", onScroll);
          }
        };
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      document.addEventListener("astro:page-load", () => {
        bindPage();
        bindContinueReading();
      });
    </script>
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
      html {
        scroll-padding-top: 70px; /* height of sticky header */
        background-color: #ffffff;
      }

      /* View Transitions: whiteout fade + smooth hero-image morph */
      @keyframes vt-fade-out {
        to { opacity: 0; }
      }
      @keyframes vt-fade-in {
        from { opacity: 0; }
      }

      ::view-transition-old(root) {
        animation: 320ms cubic-bezier(0.4, 0, 1, 1) both vt-fade-out;
      }
      ::view-transition-new(root) {
        animation: 320ms 280ms cubic-bezier(0, 0, 0.2, 1) both vt-fade-in;
      }

      /* Shared-element morph rides on top of the whiteout */
      ::view-transition-group(*) {
        animation-duration: 620ms;
        animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
        border-radius: 0.5rem; /* preserve rounded-lg frame during morph */
        overflow: clip;
      }
      ::view-transition-image-pair(*) {
        isolation: auto;
        border-radius: 0.5rem;
      }
      ::view-transition-old(*),
      ::view-transition-new(*) {
        animation-duration: 620ms;
        animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
        mix-blend-mode: normal;
        border-radius: 0.5rem;
      }
      /* Root pair is full-viewport — undo rounding so the page does not clip */
      ::view-transition-group(root),
      ::view-transition-image-pair(root),
      ::view-transition-old(root),
      ::view-transition-new(root) {
        border-radius: 0;
      }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-group(*),
        ::view-transition-old(*),
        ::view-transition-new(*) {
          animation-duration: 1ms !important;
        }
      }
    </style>
    <style>
      .email-sidelink {
        writing-mode: vertical-lr;
      }

      .email-sidelink a::after {
        content: "";
        height: 100%;
        position: absolute;
        transform: scaleY(0);
        width: 2px;
        top: 0;
        left: 0;
        transform-origin: bottom left;
        transition: transform 0.25s ease-out;
      }

      .email-sidelink a:hover::after {
        transform: scaleX(1);
        transform-origin: top left;
      }
      .socials-side {
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        list-style: none;
      }

      .socials-side li {
        margin-bottom: 12px;
      }

      .socials-side li a:hover {
        transform: scale(1.1);
      }
    </style>
  </body>
</html>
