---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import TechnoBadges from "@components/techno-badges.astro";

export async function getStaticPaths() {
  const portfolioEntries = await getCollection("portfolio");
  return portfolioEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/portfolio/*.{png,jpg,jpeg,webp,avif,gif}",
  { eager: true },
);
const imagesByName = Object.fromEntries(
  Object.entries(portfolioImages).map(([path, mod]) => [
    path.split("/").pop()!,
    mod.default,
  ]),
);
const heroMeta = imagesByName[entry.data.image.src];
const heroIsAnimated = /\.gif$/i.test(entry.data.image.src);
const heroName = `hero-${entry.id}`;

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    month: "short",
    year: "numeric",
  });
};
---

<Layout title={entry.data.title}>
  <Container>
    <div class="mx-auto max-w-4xl mt-8">
      <a
        href={`/#project-${entry.id}`}
        class="text-gray-500 hover:text-gray-700 transition inline-flex items-center gap-2 mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to projects
      </a>

      <div class="watermark-hover rounded-lg shadow-lg mb-8 overflow-hidden" transition:name={heroName}>
        {heroMeta && !heroIsAnimated ? (
          <Image
            src={heroMeta}
            alt={entry.data.image.alt}
            widths={[400, 800, 1200, 1600]}
            sizes="(min-width: 896px) 896px, 100vw"
            loading="eager"
            class="w-full rounded-lg"
            data-parallax="0.05"
          />
        ) : (
          <img
            src={heroMeta ? heroMeta.src : entry.data.image.src}
            alt={entry.data.image.alt}
            class="w-full rounded-lg"
            data-parallax="0.05"
          />
        )}
      </div>

      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>

      <p class="text-xl text-gray-600 mt-4">{entry.data.snippet}</p>

      <div class="flex gap-4 mt-6 items-center flex-wrap">
        <time class="text-gray-500">
          {formatDate(entry.data.startDate)} - {entry.data.endDate ? formatDate(entry.data.endDate) : "Present"}
        </time>
        <span class="text-gray-300">|</span>
        <TechnoBadges technos={entry.data.technos} />
      </div>

      {
        (entry.data.github || entry.data.demo) && (
          <div class="flex gap-4 mt-6">
            {entry.data.github && (
              <a
                href={entry.data.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-700 transition"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                View on GitHub
              </a>
            )}
            {entry.data.demo && (
              <a
                href={entry.data.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-500 transition"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
                Live Demo
              </a>
            )}
          </div>
        )
      }

      <hr class="my-8 border-gray-200" />

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>

      <div class="text-center mt-12 mb-8">
        <a
          href={`/#project-${entry.id}`}
          class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition"
        >
          ← Back to Projects
        </a>
      </div>
    </div>
  </Container>

  <button
    id="continue-reading"
    type="button"
    class="continue-reading-btn fixed bottom-6 right-6 z-40 inline-flex items-center gap-2 bg-gray-900 text-white px-5 py-3 rounded-full shadow-lg hover:bg-gray-700"
  >
    Continue reading
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 5v14" />
      <path d="m19 12-7 7-7-7" />
    </svg>
  </button>
</Layout>

<style>
  .continue-reading-btn {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 280ms ease, transform 280ms ease, background-color 200ms ease;
  }
  .continue-reading-btn.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>
